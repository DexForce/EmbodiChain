{
  "trainer": {
    "gym_config": "configs/agents/rl/basic/cart_pole/gym_config.json",
    "exp_name": "cart_pole_grpo_seed0",
    "device": "cuda:0",
    "headless": true,
    "enable_rt": false,
    "gpu_id": 0,
    "num_envs": 64,
    "iterations": 80,
    "buffer_size": 1024,
    "enable_eval": true,
    "num_eval_envs": 16,
    "num_eval_episodes": 20,
    "eval_freq": 200,
    "save_freq": 200,
    "use_wandb": false,
    "events": {},
    "seed": 0
  },
  "policy": {
    "name": "actor_only",
    "actor": {
      "type": "mlp",
      "network_cfg": {
        "hidden_sizes": [
          256,
          256
        ],
        "activation": "relu"
      }
    }
  },
  "algorithm": {
    "name": "grpo",
    "cfg": {
      "learning_rate": 0.0001,
      "n_epochs": 10,
      "batch_size": 8192,
      "gamma": 0.99,
      "clip_coef": 0.2,
      "ent_coef": 0.01,
      "kl_coef": 0.0,
      "group_size": 4,
      "eps": 1e-08,
      "reset_every_rollout": true,
      "truncate_at_first_done": true,
      "max_grad_norm": 0.5
    }
  }
}