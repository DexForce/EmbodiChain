{
    "id": "StackBowls-v1",
    "max_episodes": 10,
    "max_episode_steps": 300,
    "env": {
        "events": {
            "record_camera": {
                "func": "record_camera_data",
                "mode": "interval",
                "interval_step": 1,
                "params": {
                    "name": "cam1",
                    "resolution": [320, 240],
                    "eye": [2, 0, 2],
                    "target": [0.5, 0, 1]
                }
            },
            "randomize_table_height": {
                "func": "randomize_rigid_object_pose",
                "mode": "reset",
                "params": {
                    "entity_cfg": {"uid": "table"},
                    "position_range": [[0.0, 0.0, -0.02], [0.00, 0.00, 0.02]],
                    "relative_position": true                
                }
            },
            "place_bowls": {
                "func": "planner_grid_cell_sampler",
                "mode": "reset",
                "params": {
                    "object_uid_list": ["bowl_max", "bowl_mid", "bowl_min"],
                    "position_range": [[0.4, -0.3], [0.8, 0.3]],
                    "reference_height": 0.8,
                    "grid_size": [2, 3],
                    "physics_update_step": 10
                }
            },
            "set_table_material": {
                "func": "set_rigid_object_visual_material",
                "mode": "startup",
                "params": {
                    "entity_cfg": {"uid": "table"},
                    "mat_cfg": {
                        "uid": "table_mat",
                        "base_color": [1.0, 1.0, 1.0, 1.0],
                        "metallic": 0.0,
                        "roughness": 0.8
                    }
                }
            },
            "set_bowl_max_material": {
                "func": "set_rigid_object_visual_material",
                "mode": "startup",
                "params": {
                    "entity_cfg": {"uid": "bowl_max"},
                    "mat_cfg": {
                        "uid": "bowl_max_mat",
                        "base_color": [0.545, 0.505, 0.431, 1.0],
                        "metallic": 0.2,
                        "roughness": 0.8
                    }
                }
            },
            "set_bowl_mid_material": {
                "func": "set_rigid_object_visual_material",
                "mode": "startup",
                "params": {
                    "entity_cfg": {"uid": "bowl_mid"},
                    "mat_cfg": {
                        "uid": "bowl_mid_mat",
                        "base_color": [0.329, 0.478, 0.589, 1.0],
                        "metallic": 0.2,
                        "roughness": 0.8
                    }
                }
            },
            "set_bowl_min_material": {
                "func": "set_rigid_object_visual_material",
                "mode": "startup",
                "params": {
                    "entity_cfg": {"uid": "bowl_min"},
