                "params": {
                    "name": "cam1",
                    "resolution": [320, 240],
                    "eye": [-1.25, 1.05, 1.55],
                    "target": [0.12, 1.84, 0.78]
                }
            },
            "validation_cameras": {
                "func": "validation_cameras",
                "mode": "trigger",
                "params": {
                    "cameras": [
