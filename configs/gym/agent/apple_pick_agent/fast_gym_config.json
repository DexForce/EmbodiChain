{
    "id": "AtomicActionsAgent-v3",
    "max_episodes": 1,
    "max_episode_steps": 600,
    "env": {
        "extensions": {
            "single_arm_name": "right_arm",
            "single_eef_name": "right_eef",
            "agent_arm_slots": {
                "right": {
                    "arm": "right_arm",
                    "eef": "right_eef"
                }
            },
            "arm_aim_yaw_offset": 3.141592653589793,
            "gripper_open_state": [0.0],
            "gripper_close_state": [0.04],
            "agent_success_object": "cup",
            "agent_success_container": "mug",
            "agent_success_position": null,
            "agent_success_tolerance": 0.05,
            "container_success_radius": 0.12,
            "container_success_min_z_offset": -0.03,
            "container_success_max_z_offset": 0.25,
