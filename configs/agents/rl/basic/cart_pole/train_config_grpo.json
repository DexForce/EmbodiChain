{
    "trainer": {
        "exp_name": "cart_pole_grpo",
        "gym_config": "configs/agents/rl/basic/cart_pole/gym_config.json",
        "seed": 42,
        "device": "cpu",
        "headless": true,
        "enable_rt": false,
        "gpu_id": 0,
        "num_envs": 64,
        "iterations": 1000,
        "rollout_steps": 1024,
        "eval_freq": 200,
        "save_freq": 200,
        "use_wandb": true,
        "enable_eval": true,
        "wandb_project_name": "embodychain-cart_pole"
    },
    "policy": {
        "name": "actor_only",
        "actor": {
            "type": "mlp",
            "network_cfg": {
                "hidden_sizes": [256, 256],
                "activation": "relu"
            }
        }
    },
    "algorithm": {
        "name": "grpo",
        "cfg": {
            "learning_rate": 0.0001,
            "n_epochs": 10,
            "batch_size": 8192,
            "gamma": 0.99,
            "clip_coef": 0.2,
            "ent_coef": 0.001,
            "kl_coef": 0.0,
            "group_size": 4,
            "eps": 1e-8,
            "reset_every_rollout": true,
            "max_grad_norm": 0.5,
            "truncate_at_first_done": true
        }
    }
}