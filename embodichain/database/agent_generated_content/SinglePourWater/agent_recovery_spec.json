{
  "task": "Pour from bottle into cup and place bottle",
  "recovery_bindings": [
    {
      "edge_id": "e01_grasp_bottle",
      "failure_name": "bottle_shifted_during_grasp",
      "monitors": [
        {
          "type": "object_moved",
          "objects": [
            "bottle"
          ],
          "threshold": 0.02
        }
      ],
      "recovery": [
        {
          "type": "regrasp",
          "robot_name": "right_arm",
          "obj_name": "bottle",
          "pre_grasp_dis": 0.1
